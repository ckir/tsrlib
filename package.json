{
  "name": "tsrlib",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "description": "Unified TSRLIB SDK with automated binary distribution and sidecar management",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "tsrlib": "./dist/cli.js"
  },
  "files": [
    "dist",
    "packages/sidecars/vector/vector.toml",
    "packages/sidecars/caddy/Caddyfile"
  ],
  "scripts": {
    "/* --- Maintainer: Rust FFI & Build --- */": "",
    "build:ffi": "napi build --platform --esm -p rsdk-ffi --release --js ../../../tsdk/src/rsdk.js --dts ../../../tsdk/src/rsdk.d.ts",
    "build:ffi:debug": "napi build --platform --esm -p rsdk-ffi --js ../../../tsdk/src/rsdk.js --dts ../../../tsdk/src/rsdk.d.ts",
    "artifacts": "napi artifacts --dist packages/tsdk/npm",
    "/* --- Maintainer: Dev Tools --- */": "",
    "cockpit": "bun scripts/devcockpit.js || tsx scripts/devcockpit.js",
    "format": "prettier --write .",
    "lint": "eslint .",
    "docs:ts": "typedoc",
    "test": "vitest run --config packages/tsdk/vitest.config.ts",
    "/* --- Distribution: Consumer Scripts --- */": "",
    "install:dev": "cross-env TSR_DEV=true pnpm install",
    "prepare": "pnpm run build",
    "build": "tsup packages/tsdk/src/index.ts scripts/cli.ts scripts/sync-binaries.ts --format esm --dts --clean --out-dir dist",
    "postinstall": "node dist/sync-binaries.js || npx tsx scripts/sync-binaries.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "commander": "^14.0.3",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@napi-rs/cli": "^3.0.0-alpha.63",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.2",
    "prettier": "^3.2.0",
    "shx": "^0.4.0",
    "tsx": "^4.21.0",
    "tsup": "^8.0.2",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">= 18"
  },
  "workspaces": [
    "packages/*",
    "packages/tsdk/packages/*"
  ]
}